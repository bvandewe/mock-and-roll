# Example environment configuration for Mock API Server
# Copy this file to .env and adjust values as needed

PYTHONPATH=./src
PYDEVD_DISABLE_FILE_VALIDATION=1
LOG_LEVEL="DEBUG"

# Documentation settings
DOCS_SITE_NAME="Mock-and-Roll"
DOCS_SITE_URL="https://bvandewe.github.io/mock-and-roll/"
DOCS_FOLDER=./docs
DOCS_DEV_PORT=8010

# Note: For Docker deployment, these are set in docker-compose.yml

# For local development, use the .env file

# Application Configuration
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Application title shown in OpenAPI/Swagger docs
APP_TITLE=Mock API Server

# Redis Configuration (for local development)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Application Configuration
LOG_LEVEL=DEBUG
APP_TITLE=Mock API Server - Development

# Optional: Custom config paths (uncomment to override defaults)
# AUTH_CONFIG_PATH=./src/config/auth.json
# ENDPOINTS_CONFIG_PATH=./src/config/endpoints.json
